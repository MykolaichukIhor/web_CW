# ==========================
# Python & Django Core
# ==========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Local databases (Never commit your production database)
db.sqlite3
db.sqlite3-journal

# ==========================
# Application Specific
# ==========================
# Ignore media folder with test photos
myimageapp/media/

# ==========================
# Confidential & Environment
# ==========================
# Sensitive data (secret keys, passwords, API tokens)
.env
env/
venv/
ENV/
.venv/
*/env/
*/venv/

# ==========================
# Static & Media
# ==========================
# General media and static collected files
media/
static/
staticfiles/

# ==========================
# Logs & Temporary files
# ==========================
*.log
local_settings.py

# ==========================
# OS & IDE Settings
# ==========================
# macOS system files
.DS_Store

# IDEs (VS Code, PyCharm, etc.)
.vscode/
.idea/
*.swp
*.bak